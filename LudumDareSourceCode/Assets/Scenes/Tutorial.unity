  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "In this game you will play as a signal manager, operating a robot traveling
    through a levels in an abandoned facility. Your main goal will be leading robot
    through each of 10 unique levels and reaching portal safe and sound by solving
    puzzles and avoiding/disactivating enemies.\r\n\r\nControls:\r\n\r\nArrow Keys
    \u2014 click to give robot a prompt to work with(right, left, up and down accordingly)
    \r\n\r\n!Note: You can see all your commands in action before activating the
    robot(look at a translucent copy of the robot)!\r\n\r\n!Note2: You can not go
    back with main robot, choose your root wisely!\r\n\r\n\"Z\" key \u2014 to undo
    the most recent command.\r\n\r\n!Note3: To interact with a station or unlock
    the door you should step on a pressure plate connected with it!\r\n\r\nHave fun.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: afcc44eb27f1c0c4d8467bf0bdf66352, type: 2}
